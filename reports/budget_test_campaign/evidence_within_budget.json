    "recipes": [
      {
        "id": 402,
        "external_id": 257409,
        "name": "the mooch     zucchini sandwich",
        "description": "this family recipe was passed to me from my uncle \"moochie\" snyder. when the zucchini and tomatoes come in from the garden there is no better \"sam-mich\" on the planet!",
        "minutes": 30,
        "n_ingredients": 9,
        "n_steps": 6,
        "ingredients": [
          "zucchini",
          "garlic cloves",
          "tomatoes",
          "mayonnaise",
          "salt",
          "pepper",
          "parmesan cheese",
          "whole wheat bread",
          "ghee"
        ],
        "instructions": [
          "working in batches , pan fry the garlic and zucchini until lightly browned , turning once to brown both sides",
          "while sauting the above , toast the bread",
          "on each slice of bread spread layer of mayonnaise , salt and pepper to taste , and coat with layer of parmesan cheese",
          "on one half of sandwich put sauted zucchini",
          "on one half put fresh tomato slices",
          "put halves together and you have a marriage of flavor made in heaven"
        ],
