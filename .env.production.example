DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_ALLOWED_HOSTS=panion-backend-webapp.azurewebsites.net
DATABASE_URL=postgresql://user:password@server.postgres.database.azure.com:5432/panion?sslmode=require
OPENAI_API_KEY=replace-with-openai-key
USE_OPENAI_PARSER=1
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=https://panion-frontend-webapp.azurewebsites.net
CSRF_TRUSTED_ORIGINS=https://panion-frontend-webapp.azurewebsites.net
SECURE_SSL_REDIRECT=1
